# Selling-ops toolkit secrets. Copy to `.env` (gitignored) and fill what you use.
# Every key is OPTIONAL — features degrade gracefully when a key is missing.

# --- Pricing ---------------------------------------------------------------
# pokemontcg.io free API key (optional; raises limit ~1k → ~20k req/day).
# Get one at https://dev.pokemontcg.io/
POKEMONTCG_API_KEY=
# PriceCharting API token (~$5/mo) — graded + sealed + MTG/YGO reference prices.
# https://www.pricecharting.com/api-documentation
PRICECHARTING_TOKEN=

# --- eBay deal radar (Workflow C) ------------------------------------------
# Apify token — auction firehose + sold comps. https://console.apify.com/account/integrations
APIFY_TOKEN=
# (defaults set in config.py; override only if you find better actors)
# APIFY_SEARCH_ACTOR=scrapeworks/ebay-search-scraper
# APIFY_SOLD_ACTOR=automation-lab/ebay-sold-scraper

# eBay Browse API (optional; free per-card watchlist once your app is approved)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# --- Notifications (reprice movers + radar deal alerts) --------------------
# Telegram: create a bot via @BotFather, then message it and read chat_id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Hermes = your local iMessage gateway (see vault System Map). POST endpoint.
HERMES_NOTIFY_URL=
